#!/usr/bin/env bash
# scripts/snapshot [label] — capture every route as full-page PNGs for
# visual regression + posterity. Output:
#   snapshots/<YYYY-MM-DD>T<HHMM>__<git-short-sha>[__label]/<name>@<width>.png
#   + manifest.tsv; snapshots/latest symlink updated.
#
# Full-page method: one headless Chrome with a DevTools port; per shot a tiny
# bun CDP client sets the viewport width, navigates, waits for load +
# document.fonts.ready, then Page.captureScreenshot with
# captureBeyondViewport:true — real full-page height, no guessing. (Plain
# `--headless=new --screenshot` only captures the viewport, and trim-based
# height probing fails on this site's min-height:100vh shell.)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
export PATH="$HOME/.cargo/bin:$HOME/.proto/shims:$PATH"

CHROME=/usr/sbin/google-chrome-stable
LABEL="${1:-}"

command -v bun >/dev/null || { echo "bun is required (CDP client)" >&2; exit 1; }

# Route manifest: "url-path<TAB>name". Extend here.
ROUTES=$'/\thome
/thoughts\tthoughts
/thoughts/pesky-code\tpesky-code
/thoughts/how-bad-are-planes\tplanes-empty
/thoughts/how-bad-are-planes?from=JFK&to=LHR\tplanes-jfk-lhr
/thoughts/how-bad-are-planes?from=JFK&to=LHR&view=compare\tplanes-compare
/resume\tresume
/resume?tech=Rust\tresume-filtered-rust
/interests\tinterests
/interests/drums\tinterest-drums
/interests/swing\tinterest-swing
/interests/lifting\tinterest-lifting
/interests/keys\tinterest-keys
/interests/spire\tinterest-spire
/interests/models\tinterest-models
/interests/puzzles\tinterest-puzzles
/interests/felix\tinterest-felix
/thouhgts\tnot-found'

WIDTHS=(1440 390)
VIEW_H=900 # viewport height; full-page capture extends beyond it

# --- build ------------------------------------------------------------------
cargo build --release
topcoat asset bundle --release

# --- start server on a free port -------------------------------------------
PORT=""
for p in $(seq 4630 4699); do
    if ! (exec 3<>"/dev/tcp/127.0.0.1/$p") 2>/dev/null; then
        PORT=$p
        break
    fi
    exec 3>&- 3<&- || true
done
[ -n "$PORT" ] || { echo "no free port in 4630-4699" >&2; exit 1; }

PORT=$PORT ./target/release/bens-site &
SERVER_PID=$!

TMP="$(mktemp -d)"
CHROME_PID=""
cleanup() {
    [ -n "$CHROME_PID" ] && kill "$CHROME_PID" 2>/dev/null || true
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
    sleep 0.5 # let chrome release its profile
    rm -rf "$TMP" 2>/dev/null || true
}
trap cleanup EXIT

BASE="http://127.0.0.1:$PORT"
for _ in $(seq 1 60); do
    curl -sf -o /dev/null "$BASE/" && break
    kill -0 "$SERVER_PID" 2>/dev/null || { echo "server died during startup" >&2; exit 1; }
    sleep 0.5
done
curl -sf -o /dev/null "$BASE/" || { echo "server not ready after 30s" >&2; exit 1; }

# --- start headless Chrome with a DevTools port -----------------------------
# --force-prefers-reduced-motion: snapshots must be deterministic — without it
# the receipt's print-feed animation is mid-flight at capture time.
"$CHROME" --headless=new --disable-gpu --hide-scrollbars \
    --force-device-scale-factor=1 --disable-extensions \
    --force-prefers-reduced-motion \
    --remote-debugging-port=0 --remote-allow-origins='*' \
    --user-data-dir="$TMP/profile" \
    about:blank >/dev/null 2>&1 &
CHROME_PID=$!

DEVTOOLS_PORT=""
for _ in $(seq 1 60); do
    [ -s "$TMP/profile/DevToolsActivePort" ] && { DEVTOOLS_PORT="$(head -1 "$TMP/profile/DevToolsActivePort")"; break; }
    sleep 0.5
done
[ -n "$DEVTOOLS_PORT" ] || { echo "chrome DevTools port never appeared" >&2; exit 1; }

# --- CDP shot client (bun) --------------------------------------------------
cat >"$TMP/shot.js" <<'EOF'
// usage: bun shot.js <devtools-port> <page-url> <width> <viewport-h> <out.png>
const [port, url, width, viewH, out] = process.argv.slice(2);
const list = await (await fetch(`http://127.0.0.1:${port}/json/list`)).json();
const target = list.find((t) => t.type === "page");
if (!target) { console.error("no page target"); process.exit(1); }
const ws = new WebSocket(target.webSocketDebuggerUrl);
let id = 0;
const pending = new Map();
let onLoad = null;
const send = (method, params = {}) =>
  new Promise((resolve) => {
    const i = ++id;
    pending.set(i, resolve);
    ws.send(JSON.stringify({ id: i, method, params }));
  });
ws.onmessage = (ev) => {
  const m = JSON.parse(ev.data);
  if (m.id && pending.has(m.id)) {
    pending.get(m.id)(m);
    pending.delete(m.id);
  } else if (m.method === "Page.loadEventFired" && onLoad) onLoad();
};
setTimeout(() => { console.error("shot timeout: " + url); process.exit(1); }, 30000);
ws.onerror = () => { console.error("websocket error"); process.exit(1); };
ws.onopen = async () => {
  const loaded = new Promise((r) => (onLoad = r));
  await send("Page.enable");
  await send("Emulation.setDeviceMetricsOverride", {
    width: +width, height: +viewH, deviceScaleFactor: 1, mobile: false,
  });
  await send("Page.navigate", { url });
  await loaded;
  await send("Runtime.evaluate", {
    expression: "document.fonts.ready.then(() => 1)", awaitPromise: true,
  });
  await new Promise((r) => setTimeout(r, 250)); // settle (print-feed CSS etc.)
  const shot = await send("Page.captureScreenshot", {
    format: "png", captureBeyondViewport: true,
  });
  if (!shot.result?.data) {
    console.error("captureScreenshot failed: " + JSON.stringify(shot.error ?? shot));
    process.exit(1);
  }
  await Bun.write(out, Uint8Array.from(atob(shot.result.data), (c) => c.charCodeAt(0)));
  process.exit(0);
};
EOF

# --- output dir -------------------------------------------------------------
SHA="$(git rev-parse --short HEAD)"
STAMP="$(date -u +%Y-%m-%dT%H%M)"
DIR="snapshots/${STAMP}__${SHA}"
[ -n "$LABEL" ] && DIR="${DIR}__${LABEL}"
mkdir -p "$DIR"

MANIFEST="$DIR/manifest.tsv"
{
    echo "# snapshot ${STAMP} sha=${SHA}${LABEL:+ label=${LABEL}} base=${BASE}"
    echo "# full-page via CDP Page.captureScreenshot captureBeyondViewport (viewport ${VIEW_H}px)"
    printf 'name\turl\twidth\tfile\tbytes\tdimensions\n'
} >"$MANIFEST"

while IFS=$'\t' read -r path name; do
    [ -n "$name" ] || continue
    for width in "${WIDTHS[@]}"; do
        out="$DIR/${name}@${width}.png"
        bun "$TMP/shot.js" "$DEVTOOLS_PORT" "$BASE$path" "$width" "$VIEW_H" "$out"
        bytes="$(stat -c %s "$out")"
        dims="$(magick identify -format '%wx%h' "$out")"
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$name" "$path" "$width" "$(basename "$out")" "$bytes" "$dims" >>"$MANIFEST"
        echo "  $name@$width -> $dims ($bytes bytes)"
    done
done <<<"$ROUTES"

ln -sfn "$(basename "$DIR")" snapshots/latest
echo "snapshot: $DIR"
