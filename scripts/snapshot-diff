#!/usr/bin/env bash
# scripts/snapshot-diff <dirA> <dirB> — per-PNG pixel diff between two
# snapshot dirs. Writes diff-<name>.png heatmaps into a diffs dir and prints
# a summary table. Exit nonzero if any image drifted (or exists in only one
# dir, or changed size). Eyeball-driven — no threshold config.
set -uo pipefail

COMPARE=/usr/sbin/compare

[ $# -eq 2 ] || { echo "usage: $(basename "$0") <dirA> <dirB>" >&2; exit 2; }
A="${1%/}"
B="${2%/}"
[ -d "$A" ] || { echo "not a directory: $A" >&2; exit 2; }
[ -d "$B" ] || { echo "not a directory: $B" >&2; exit 2; }

OUT="${DIFF_OUT:-diffs__$(basename "$A")__vs__$(basename "$B")}"
mkdir -p "$OUT"

drift=0
printf '%-28s %-14s %s\n' 'image' 'pixels (AE)' 'verdict'
printf '%-28s %-14s %s\n' '----------------------------' '--------------' '-------'

# All PNG names across both dirs, sorted.
names="$( { (cd "$A" && ls -- *.png 2>/dev/null); (cd "$B" && ls -- *.png 2>/dev/null); } | sort -u)"
[ -n "$names" ] || { echo "no PNGs found in either dir" >&2; exit 2; }

while IFS= read -r name; do
    fa="$A/$name"
    fb="$B/$name"
    if [ ! -f "$fa" ]; then
        printf '%-28s %-14s %s\n' "$name" '-' "ONLY IN $B"
        drift=1
        continue
    fi
    if [ ! -f "$fb" ]; then
        printf '%-28s %-14s %s\n' "$name" '-' "ONLY IN $A"
        drift=1
        continue
    fi

    da="$(magick identify -format '%wx%h' "$fa")"
    db="$(magick identify -format '%wx%h' "$fb")"
    if [ "$da" != "$db" ]; then
        printf '%-28s %-14s %s\n' "$name" '-' "DIFFERENT SIZE ($da vs $db)"
        drift=1
        continue
    fi

    # AE prints as "N" or "N (normalized)"; exit status is the verdict:
    # 0 identical, 1 differs, >1 error.
    ae="$("$COMPARE" -metric AE "$fa" "$fb" "$OUT/diff-$name" 2>&1)"
    status=$?
    ae="${ae%% *}"
    if [ $status -eq 0 ]; then
        printf '%-28s %-14s %s\n' "$name" "$ae" 'identical'
        rm -f "$OUT/diff-$name"
    elif [ $status -eq 1 ]; then
        printf '%-28s %-14s %s\n' "$name" "$ae" "DIFFERS -> $OUT/diff-$name"
        drift=1
    else
        printf '%-28s %-14s %s\n' "$name" '-' "COMPARE ERROR ($ae)"
        drift=1
    fi
done <<<"$names"

rmdir "$OUT" 2>/dev/null || true
if [ $drift -ne 0 ]; then
    echo
    echo "pixel drift detected"
fi
exit $drift
