# Toolchain pins for bens-site (managed with proto).
# topcoat 0.1.3 requires Rust >= 1.95; proto's rust tool delegates to rustup.
rust = "~1.97"
just = "1.51.0"
lefthook = "2.1.9"

[plugins.tools]
lefthook = "https://raw.githubusercontent.com/ageha734/proto-plugins/refs/heads/master/toml/lefthook.toml"
